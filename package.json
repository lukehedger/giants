{
  "name": "giants",
  "private": true,
  "workspaces": [
    "api",
    "bootstrap",
    "infra",
    "packages/*"
  ],
  "scripts": {
    "fmt": "biome check ./ --write",
    "test:unit": "POWERTOOLS_LOG_LEVEL=SILENT turbo test:unit",
    "types": "tsc --noEmit"
  },
  "packageManager": "bun@1.3.11",
  "catalog": {
    "@aws-lambda-powertools/logger": "2.33.0",
    "@aws-lambda-powertools/metrics": "2.33.0",
    "@aws-lambda-powertools/parameters": "2.33.0",
    "@aws-lambda-powertools/tracer": "2.33.0",
    "@aws-sdk/client-appconfigdata": "3.1041.0",
    "@aws-sdk/client-dynamodb": "3.1041.0",
    "@aws-sdk/client-secrets-manager": "3.1041.0",
    "@aws-sdk/lib-dynamodb": "3.1041.0",
    "@types/aws-lambda": "8.10.161",
    "aws-cdk": "2.1120.0",
    "aws-cdk-lib": "2.252.0",
    "aws-cdk-local": "3.0.4",
    "constructs": "10.6.0",
    "esbuild": "0.28.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "esbuild": "^0.28.0",
    "turbo": "^2.9.8"
  },
  "peerDependencies": {
    "typescript": "^6.0.3"
  }
}
